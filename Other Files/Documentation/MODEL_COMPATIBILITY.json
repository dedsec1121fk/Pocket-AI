{
  "package": "Pocket AI Hybrid Automatic Model Pack",
  "package_version": 19,
  "target": "Termux on unrooted Android phones, with shared bilingual grade 1-12 school support and no-key public web learning",
  "automatic_scan": {
    "checks": [
      "processor identifiers and family",
      "ABI and 32/64-bit userspace",
      "logical cores and CPU frequency",
      "short integer and floating-point benchmark",
      "total and currently available RAM",
      "free application and shared storage",
      "bundled model presence",
      "live thermal-zone and battery temperature",
      "battery level, health, charging and power-saving state",
      "GGUF header and SHA-256 integrity during full scan",
      "resource pressure between sequential hybrid passes"
    ],
    "unknown_processor_fallback": true,
    "loads_simultaneous_gguf_models": 1,
    "classifier_profiles": [
      "micro",
      "lite",
      "balanced",
      "standard",
      "max"
    ],
    "task_specialists": [
      "code",
      "math",
      "research",
      "school_math",
      "school_science",
      "school_language",
      "school_humanities",
      "school_computing"
    ],
    "hybrid_modes": [
      "off",
      "speed",
      "smart",
      "quality",
      "adaptive",
      "expert",
      "consensus",
      "cascade",
      "auto"
    ],
    "shared_foundations": [
      "English/Greek conversation",
      "grade 1-12 school foundation",
      "deterministic school mathematics",
      "persistent retrieval memory",
      "safe no-key public web learning"
    ]
  },
