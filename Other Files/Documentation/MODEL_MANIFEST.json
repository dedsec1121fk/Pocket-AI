  "language_policy": [
    "English",
    "Greek"
  ],
  "runner": {
    "name": "llama.cpp llama-cli",
    "bundled": false,
    "installer": "Other Files/install_models.sh",
    "reason": "Native runner is compiled for the phone architecture; all AI model data is already bundled"
  },
  "package_structure": {
    "main_script": "Pocket AI.py",
    "models_folder": "Models",
    "other_files_folder": "Other Files",
    "generated_data_folder": "Other Files/Saved Data",
    "github_readme": "README.md",
    "runtime_modules": "Other Files/Modules/"
  },
  "persona_system": {
    "persistent_file": "Other Files/Saved Data/persona.json",
    "styles": [
      "friendly",
      "calm_expert",
      "casual",
      "mentor",
      "direct"
    ],
    "commands": [
      "/persona",
      "/name",
      "/style",
      "/human"
    ],
    "disclosure": "Natural conversation style; the assistant still identifies as AI."
  },
  "hybrid_modes": [
    "auto",
    "off",
    "speed",
    "smart",
    "quality",
    "adaptive",
    "expert",
    "consensus",
    "cascade"
  ],
